- const userId = user && user.id ? user.id : ''
- const bookingId = room && room.bookingId ? room.bookingId : ''

article(
    class='room js-room'
    data-user=userId
    data-room=room.id
    data-price=room.price
    data-booking=bookingId
    )
    header(class='room__header')
        div(class='room__src')
            img(class='room__img', src=room.images[0])
            div(class='room__number')= room.number
    div(class='room__main')
        h2(class='room__name')
            a(class='room__link' href='#')= room.title
        div(class='room_description')= room.description
    footer(class='room__footer')
        div(class='room__status')= room.status
        div(class='room__price')= room.price
        if room.isBooked && room.isBookedByCurrentUser
            button(class='room__btn --cancel js-booking-cancel') Отменить бронирование
        else if room.isBooked
            button(class='room__btn --confirmed') Забронировано
        else
            button(class='room__btn js-fr') Забронировать